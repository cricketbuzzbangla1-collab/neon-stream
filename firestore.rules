rules_version = '2';

service cloud.firestore {

  match /databases/{database}/documents {

    // --------------------
    // HELPER FUNCTIONS
    // --------------------

    function isLoggedIn() {
      return request.auth != null;
    }

    function isAdmin() {
      return request.auth != null &&
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == "admin";
    }

    function isModerator() {
      return request.auth != null &&
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == "moderator";
    }

    function isAdminOrMod() {
      return isAdmin() || isModerator();
    }

    function isValidGlobalChatPayload(data) {
      return data.keys().hasAll([
          "id","userId","userName","message","channelId","createdAt","likes","badges","isDeleted"
        ])
        && data.id is string
        && data.userId is string
        && data.userName is string
        && data.message is string
        && data.channelId is string
        && data.createdAt is number
        && data.likes is list
        && data.badges is list
        && data.isDeleted is bool;
    }

    // --------------------
    // USERS
    // --------------------

    match /users/{userId} {
      allow create: if true;
      allow read: if true;
      allow update: if isLoggedIn() && (request.auth.uid == userId || isAdmin());
      allow delete: if isAdmin();

      // USER PLAYLISTS
      match /playlists/{playlistId} {
        allow read, write: if isLoggedIn() && request.auth.uid == userId;
      }

      // USER THEMES
      match /theme/{themeId} {
        allow read: if isLoggedIn();
        allow write: if isLoggedIn() && request.auth.uid == userId;
      }

      // USER FAVORITES
      match /favorites/{channelId} {
        allow read, write: if isLoggedIn() && request.auth.uid == userId;
      }
    }

    // --------------------
    // CHANNELS
    // --------------------

    match /channels/{channelId} {
      allow read: if true;
      allow create, update, delete: if isAdmin();

      // CHANNEL CHAT MIRROR (same message ID as globalChat)
      match /messages/{messageId} {
        allow read: if true;
        allow create, update: if isLoggedIn();
        allow delete: if isAdminOrMod();
      }
    }

    // --------------------
    // LIVE EVENTS
    // --------------------

    match /liveEvents/{eventId} {
      allow read: if true;
      allow create, update, delete: if isAdmin();
    }

    // --------------------
    // CATEGORIES
    // --------------------

    match /categories/{categoryId} {
      allow read: if true;
      allow create, update, delete: if isAdmin();
    }

    // --------------------
    // COUNTRIES
    // --------------------

    match /countries/{countryId} {
      allow read: if true;
      allow create, update, delete: if isAdmin();
    }

    // --------------------
    // GLOBAL CHAT (ALL CHANNELS SHARE SAME CHAT)
    // Flat collection: /globalChat/{messageId}
    // --------------------

    match /globalChat/{messageId} {
      allow read: if true;
      allow create: if isLoggedIn() && isValidGlobalChatPayload(request.resource.data);
      allow update: if isLoggedIn()
        && request.resource.data.diff(resource.data).affectedKeys().hasOnly(["likes","isDeleted"]);
      allow delete: if isAdminOrMod();
    }

    // --------------------
    // POSTS
    // --------------------

    match /posts/{postId} {
      allow read: if true;
      allow create: if isLoggedIn();
      allow update: if isLoggedIn();
      allow delete: if isAdminOrMod();
    }

    // --------------------
    // POLLS
    // --------------------

    match /polls/{pollId} {
      allow read: if true;
      allow create: if isLoggedIn();
      allow update: if isLoggedIn();
      allow delete: if isAdmin();
    }

    // --------------------
    // ADS
    // --------------------

    match /ads/{adId} {
      allow read: if true;
      allow create, update, delete: if isAdmin();
    }

    // --------------------
    // APP SETTINGS
    // --------------------

    match /appSettings/{docId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // --------------------
    // CHANNEL REPORTS
    // --------------------

    match /channelReports/{reportId} {
      allow create: if isLoggedIn();
      allow read, update, delete: if isAdmin();
    }

    // --------------------
    // ONLINE USERS (PRESENCE)
    // --------------------

    match /onlineUsers/{uid} {
      allow read: if isAdmin();
      allow create, update: if isLoggedIn() && request.auth.uid == uid;
      allow delete: if isLoggedIn() && request.auth.uid == uid;
    }

  }
}
